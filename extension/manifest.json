{
  "manifest_version": 3,
  "name": "V1 Helper for Chrome",
  "version": "0.2.0",
  "description": "Vision One Container Security helper — CVE analysis overlays, relevance badges, quick triage.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.trendmicro.com/*"
  ],
  "background": {
    "service_worker": "chrome/src/background-module.js"
  },
  "action": {
    "default_title": "V1 Helper for Chrome",
    "default_popup": "chrome/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.trendmicro.com/*"],
      "js": ["chrome/src/content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
